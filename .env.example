# WAZCOR Environment Variables

# App
APP_VERSION=1.0.0
NODE_ENV=development

# Backend
# Database: mongodb://mongo:27017/wazcor
DATABASE_URL=mongodb://mongo:27017/wazcor

# AI Provider: mock, gemini, openai
AI_PROVIDER=mock
GEMINI_API_KEY=
# For Ollama/local models:
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama
OPENAI_MODEL=qwen3:8b

# Evidence Source: mock, elastic
EVIDENCE_SOURCE=mock
ELASTIC_URL=
ELASTIC_API_KEY=
ELASTIC_USERNAME=
ELASTIC_PASSWORD=
ELASTIC_ALERT_INDEX=wazuh-alerts-*

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
